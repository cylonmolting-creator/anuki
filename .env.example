# ═══════════════════════════════════════════════════════
# Anuki — AI Agent LEGO Platform
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Server port (default: 3000)
PORT=3000

# ── LLM Provider ──────────────────────────────────────
# Which LLM backend to use: claude, openai, ollama
# Default: claude (if not set, Claude Code CLI is used)
# LLM_PROVIDER=claude

# ── Claude (default) ─────────────────────────────────
# Claude Code CLI path (auto-detected if on PATH)
# CLAUDE_PATH=/usr/local/bin/claude
# Anthropic API key (for BYOK — bring your own key)
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (optional) ────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama (optional, free local models) ─────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Security ────────────────────────────────────────────
# API authentication token (optional — if set, all /api/* endpoints require Bearer token)
# API_AUTH_TOKEN=your-secret-token-here

# ── General ───────────────────────────────────────────
# Logging level: debug, info, warn, error
LOG_LEVEL=info
